# CamCCUL Core Banking System - Environment Configuration

# Application Settings
DEBUG=false
APP_NAME="CamCCUL Core Banking System"
APP_VERSION="1.0.0"

# Security Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database Settings
DATABASE_URL=postgresql://camccul:camccul_secure_password@db:5432/camccul_banking

# Business Rules
MIN_DEPOSIT_AMOUNT=100
MAX_WITHDRAWAL_AMOUNT=5000000
FOUR_EYES_THRESHOLD=500000
DEFAULT_DELINQUENCY_DAYS=30

# COBAC Settings
COBAC_INSTITUTION_CODE=CAMCCUL001

# Data Sovereignty
DATA_CENTER_REGION=Camtel-Zamengoue

# Sync Settings
SYNC_BATCH_SIZE=100
MAX_OFFLINE_DAYS=7

# Redis Settings (optional)
REDIS_URL=redis://redis:6379/0